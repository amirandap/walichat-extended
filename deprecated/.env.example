# WaliChat Extended MCP — Environment Variables
# Copy this file to .env and fill in your values

# Your WaliChat API key (found at app.wali.chat → Settings → API)
WALICHAT_API_KEY=your_api_key_here

# Default WhatsApp device ID (24-char hex, found at app.wali.chat → Devices)
WALICHAT_DEVICE_ID=your_device_id_here
